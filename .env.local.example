# EmailJS 설정 (https://www.emailjs.com) — 무료 계정 가입 후 발급
# 이 파일은 예시입니다. 실제 값은 .env.local 에만 넣으세요(레포 커밋 금지).
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_service_id
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_template_id
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key

# (선택) 수신 이메일 — EmailJS 템플릿 "To Email"에 {{to_email}} 를 넣었을 때 사용.
# 템플릿에 수신 주소를 직접 적었다면 비워둬도 됩니다. 실제 주소는 여기(.env.local)에만.
NEXT_PUBLIC_EMAILJS_TO_EMAIL=받는사람@example.com

# ── 검색엔진 소유확인 (SEO) ────────────────────────────────
# 값이 있을 때만 <meta> 소유확인 태그가 출력됩니다(layout.tsx).
# Google Search Console → "HTML 태그" 방식의 content 값만 입력
GOOGLE_SITE_VERIFICATION=
# 네이버 서치어드바이저(searchadvisor.naver.com) → "HTML 태그" content 값만 입력
NAVER_SITE_VERIFICATION=

# ── IndexNow (선택, 색인 즉시 알림) ─────────────────────────
# 임의의 32자 이상 키를 발급해 넣고, 같은 키를 담은 파일을
# public/<INDEXNOW_KEY>.txt 로도 올려야 합니다(소유 증명).
# 설정 후: node scripts/indexnow-ping.mjs 로 변경 URL을 일괄 통보.
INDEXNOW_KEY=
